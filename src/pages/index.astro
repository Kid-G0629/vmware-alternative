---
// 首页会动态加载最新一期周报的 frontmatter，展示为 Hero
const postModules = import.meta.glob('../content/news/*.md', { eager: true });
const posts = Object.entries(postModules)
  .map(([filepath, mod]) => {
    const slug = filepath.split('/').pop()?.replace(/\.md$/, '');
    const fm = (mod as any).frontmatter;
    const volDate = fm?.date
      ? new Date(fm.date).toISOString().split('T')[0].replace(/-/g, '.')
      : '';
    return { slug, frontmatter: fm, volDate };
  })
  .filter((p) => p.frontmatter?.date)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).getTime() -
      new Date(a.frontmatter.date).getTime()
  );

const latest = posts[0];
const description = latest?.frontmatter?.description || '每周精选 VMware 替代方案最新动态，帮你 5 分钟掌握迁移关键信号。';
const latestUrl = latest ? `/news/${latest.slug}/` : '#';
---
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Infra Operator Weekly — VMware 替代方案前沿周报</title>
  </head>
  <body>
    <div class="app-layout">
      <!-- 左侧导航 -->
      <nav class="sidebar">
        <div class="logo">
          <a href="/" style="text-decoration: none; color: inherit;">
            <h2>📡 Infra <br />Operator</h2>
          </a>
        </div>
        <ul class="nav-links">
          <li><a href="/" class="active">🏠 首页</a></li>
          <li><a href="/news">📰 周报列表</a></li>
          <li><a href={latestUrl}>🔥 最新一期</a></li>
        </ul>
        <div class="sidebar-footer">
          <p>由 AI 辅助整理<br />社区来源已标注</p>
        </div>
      </nav>

      <!-- 右侧主内容 -->
      <main class="main-content">
        <section class="hero">
          <p class="eyelet">VMware 替代方案 · 每周一期</p>
          <h1>Infra Operator Weekly</h1>
          <p class="subtitle">5 分钟掌握迁移关键信号。聚焦 Broadcom 动向、替代方案成熟度与社区实战，为技术决策者节省信息筛选时间。</p>
          {latest ? (
            <div class="latest-card">
              <div class="latest-badge">📅 最新一期 · Vol. {latest.volDate}</div>
              <div class="latest-desc">{description}</div>
              <a href={latestUrl} class="btn-primary">阅读本期周报 →</a>
            </div>
          ) : (
            <div class="latest-card">
              <p>暂无周报，请先运行抓取脚本生成第一期。</p>
            </div>
          )}
        </section>

        <section class="features">
          <h2>📌 核心栏目</h2>
          <div class="feature-grid">
            <div class="feature-card">
              <h3>📋 VMware / Broadcom 动向</h3>
              <p>许可变更、产品路线、企业影响</p>
            </div>
            <div class="feature-card">
              <h3>🧩 替代方案更新</h3>
              <p>Proxmox、XCP-ng、KubeVirt 等生态进展</p>
            </div>
            <div class="feature-card">
              <h3>🧰 迁移工具/技巧</h3>
              <p>实用脚本、迁移实战与避坑方案</p>
            </div>
            <div class="feature-card">
              <h3>💰 成本观察</h3>
              <p>TCO 分析、硬件性价比与隐形开销</p>
            </div>
            <div class="feature-card">
              <h3>💬 社区热议</h3>
              <p>Reddit、Hacker News 等一线工程师情绪</p>
            </div>
            <div class="feature-card">
              <h3>⭐ GitHub 热点</h3>
              <p>开源项目趋势，提前发现技术信号</p>
            </div>
          </div>
        </section>
      </main>
    </div>
  </body>

  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      background: #0f172a;
      color: #e2e8f0;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      line-height: 1.6;
    }
    .app-layout {
      display: flex;
      min-height: 100vh;
    }
    /* 左侧导航 */
    .sidebar {
      width: 260px;
      background: #0b1120;
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      border-right: 1px solid #1e293b;
      flex-shrink: 0;
    }
    .logo h2 {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      line-height: 1.3;
      color: #f1f5f9;
    }
    .nav-links {
      list-style: none;
      flex-grow: 1;
    }
    .nav-links li {
      margin-bottom: 0.75rem;
    }
    .nav-links a {
      display: block;
      padding: 0.5rem 1rem;
      text-decoration: none;
      color: #94a3b8;
      border-radius: 8px;
      transition: background 0.15s;
    }
    .nav-links a:hover,
    .nav-links a.active {
      background: #1e293b;
      color: #e2e8f0;
    }
    .sidebar-footer {
      margin-top: auto;
      font-size: 0.8rem;
      color: #64748b;
    }
    /* 右侧主内容 */
    .main-content {
      flex: 1;
      padding: 3rem 2rem;
      max-width: 900px;
    }
    .hero {
      margin-bottom: 3rem;
    }
    .eyelet {
      font-size: 0.85rem;
      color: #60a5fa;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .hero h1 {
      font-size: 2.8rem;
      margin-bottom: 1rem;
      color: #f8fafc;
    }
    .subtitle {
      font-size: 1.1rem;
      color: #94a3b8;
      max-width: 600px;
      margin-bottom: 2rem;
    }
    .latest-card {
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      border: 1px solid #334155;
      border-radius: 16px;
      padding: 2rem;
      margin-top: 1.5rem;
    }
    .latest-badge {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: #cbd5e0;
    }
    .latest-desc {
      color: #94a3b8;
      margin-bottom: 1.5rem;
      line-height: 1.7;
    }
    .btn-primary {
      display: inline-block;
      background: #3b82f6;
      color: #fff;
      padding: 0.5rem 1.2rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.15s;
    }
    .btn-primary:hover {
      background: #2563eb;
    }
    .features h2 {
      font-size: 1.6rem;
      margin-bottom: 1.5rem;
      color: #f1f5f9;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.2rem;
    }
    .feature-card {
      background: #1a202c;
      border: 1px solid #2d3748;
      border-radius: 12px;
      padding: 1.2rem;
    }
    .feature-card h3 {
      font-size: 1rem;
      margin-bottom: 0.4rem;
      color: #e2e8f0;
    }
    .feature-card p {
      font-size: 0.9rem;
      color: #94a3b8;
    }
  </style>
</html>